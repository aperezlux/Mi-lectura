{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present",
    "db:migrate": "pnpm --filter @workspace/db migrate",
    "db:seed": "pnpm --filter @workspace/db seed"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
